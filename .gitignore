# Ignore node_modules and Python environments
node_modules/
.env
venv/
__pycache__/

# Ignore system files
.DS_Store
Thumbs.db

# Ignore editor/project files
.vscode/
.idea/
*.swp

# Ignore generated workstream docs and tasks (if not tracked)
# Keep foundational docs and requirements tracked
/workstream/*.md
/docs/*.md
!/docs/product-context.md
!/docs/technical-guidelines.md
!/docs/requirements/

# Ignore log files
*.log

# Ignore backup files
*~
*.bak

# Ignore OS trash
.Trashes
